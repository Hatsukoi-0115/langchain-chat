# .env.example —— 环境变量模板（安全配置说明）
# 使用方式：复制本文件为 .env，再填入真实值。
# 重要：永远不要把真实密钥填进 .env.example，也不要 git add .env。

# 通义千问
QWEN_API_KEY=sk-ws-你的通义key

# DeepSeek
DEEPSEEK_API_KEY=sk-你的deepseek-key

# OpenAI 代理
OPENAI_API_KEY=sk-你的openai代理key

# 默认模型（启动时使用的模型，必须是 providers 里某个模型的 value）
DEFAULT_MODEL=qwen3.6-flash

# 数据库密码（仅 MySQL 后端需要）
MYSQL_PASSWORD=your_mysql_password_here

# 运行环境（多环境区分预留，Step 15 启用）
# APP_ENV=dev
